---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "AI in Digital Humanities: Projects, Grants, Successes & Risks (2025–2026)" } = Astro.props;

const base = import.meta.env.BASE_URL;

const navItems = [
  { href: `${base}`, label: "Home" },
  { href: `${base}funding/`, label: "I. Funding" },
  { href: `${base}transcription/`, label: "II. Transcription" },
  { href: `${base}archaeology/`, label: "III. Archaeology" },
  { href: `${base}social-justice/`, label: "IV. Social Justice" },
  { href: `${base}ethics/`, label: "V. Ethics" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <title>{title} | AI in Digital Humanities</title>
  </head>
  <body class="min-h-screen bg-stone-50 text-stone-900 font-sans">
    <header class="bg-stone-800 text-stone-100 shadow-lg">
      <div class="max-w-5xl mx-auto px-6 py-6">
        <h1 class="font-serif text-2xl md:text-3xl font-bold tracking-tight">
          <a href={base} class="hover:text-amber-300 transition-colors">
            AI in Digital Humanities
          </a>
        </h1>
        <p class="text-stone-400 text-sm mt-1 font-sans">
          Connecticut Digital Humanities Conference — March 2026
        </p>
      </div>
      <nav class="bg-stone-700 border-t border-stone-600">
        <div class="max-w-5xl mx-auto px-6">
          <ul class="flex flex-wrap gap-1 py-2 text-sm">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "px-3 py-2 rounded transition-colors inline-block",
                    currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                      ? "bg-amber-600 text-white font-medium"
                      : "text-stone-300 hover:bg-stone-600 hover:text-white"
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-10">
      <article class="prose prose-stone prose-lg max-w-none
        prose-headings:font-serif prose-headings:text-stone-800
        prose-h1:text-3xl prose-h1:md:text-4xl prose-h1:font-bold prose-h1:border-b prose-h1:border-stone-300 prose-h1:pb-4 prose-h1:mb-8
        prose-h2:text-2xl prose-h2:font-semibold prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:font-semibold prose-h3:text-stone-700
        prose-p:leading-relaxed prose-p:text-stone-700
        prose-li:text-stone-700 prose-li:leading-relaxed
        prose-strong:text-stone-900
        prose-a:text-amber-700 prose-a:no-underline hover:prose-a:underline
        ">
        <slot />
      </article>
    </main>

    <footer class="bg-stone-800 text-stone-400 mt-16">
      <div class="max-w-5xl mx-auto px-6 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-sm">
            Prepared for the Connecticut Digital Humanities Conference
          </p>
          <nav class="flex gap-4 text-sm">
            <a href={base} class="hover:text-white transition-colors">Home</a>
            <span class="text-stone-600">|</span>
            <a href={`${base}funding/`} class="hover:text-white transition-colors">Funding</a>
            <span class="text-stone-600">|</span>
            <a href={`${base}ethics/`} class="hover:text-white transition-colors">Ethics</a>
          </nav>
        </div>
        <p class="text-xs text-stone-500 mt-4 text-center">
          &copy; 2026. Report content for educational purposes.
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }

  .prose h1, .prose h2, .prose h3, .prose h4 {
    font-family: 'Crimson Pro', Georgia, serif;
  }

  .font-serif {
    font-family: 'Crimson Pro', Georgia, serif;
  }

  .font-sans {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
